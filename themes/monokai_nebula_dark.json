{
  "name": "Monokai Nebula",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "annotation:dart": {
      "foreground": "#ae81ff"
    },
    "enumMember": {
      "foreground": "#66d9ff"
    },
    "macro": {
      "foreground": "#ae81ff"
    },
    "memberOperatorOverload": {
      "foreground": "#f92672"
    },
    "parameter.label:dart": {
      "foreground": "#f8f8f2"
    },
    "property:dart": {
      "foreground": "#a6ff2e"
    },
    "tomlArrayKey": {
      "foreground": "#e6db74"
    },
    "variable:dart": {
      "foreground": "#f8f8f2"
    },
    "variable.constant": {
      "foreground": "#ae81ff"
    },
    "variable.defaultLibrary": {
      "foreground": "#66d9ff"
    }
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment",
        "comment markup.link",
        "markup.quote.markdown",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#75715e"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "entity.name.namespace",
        "variable",
        "variable.other",
        "variable.parameter.function",
        "variable.other.readwrite",
        "variable.other.readwrite.c",
        "variable.parameter",
        "variable.language.rust",
        "variable:dart",
        "variable.parameter.function.language.python",
        "support.variable.property",
        "support.variable.object.process",
        "support.variable.object.node"
      ],
      "settings": {
        "foreground": "#f8f8f2"
      }
    },
    {
      "name": "Special Variables",
      "scope": [
        "variable.parameter.function.language.special.self.python"
      ],
      "settings": {
        "foreground": "#ff971f"
    }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "support.constant",
        "support.constant.math",
        "support.constant.core.rust",
        "support.constant.ext.php",
        "support.constant.std.php",
        "support.constant.core.php",
        "support.constant.parser-token.php",
        "variable.other.constant",
        "variable.other.enummember",
        "variable.constant"
      ],
      "settings": {
        "foreground": "#ae81ff"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.unquoted",
        "string.regexp",
        "string.other"
      ],
      "settings": {
        "foreground": "#e6db74"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical.python",
        "keyword.other.unit",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.definition.decorator.python"
      ],
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "meta.function-call.generic.python",
        "variable.function",
        "support.function",
        "support.function.console",
        "support.function.std.rust"
      ],
      "settings": {
        "foreground": "#a6ff2e"
      }
    },
    {
      "name": "Classes and Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.scope",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#66d9ff"
      }
    },
    {
      "name": "Markup Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "markup.heading",
        "markup.inline.raw",
        "markup.bold",
        "markup.italic"
      ],
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.bitwise"
      ],
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Assignment Operators",
      "scope": [
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#a6ff2e"
      }
    },
    {
      "name": "Unpacking Operators",
      "scope": [
        "keyword.operator.unpacking.parameter.python",
        "keyword.operator.unpacking.arguments.python"
      ],
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#f8f8f2"
      }
    },
    {
      "name": "Special Functions and Methods",
      "scope": [
        "entity.name.function.special",
        "entity.name.function.member",
        "support.function.magic",
        "support.function.builtin",
        "support.function.builtin.python",
        "keyword.other.special-method",
        "markup.inserted",
        "meta.method-call",
        "meta.method"
      ],
      "settings": {
        "foreground": "#66d9ff"
      }
    },
    {
      "name": "Object Properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "support.variable.magic.python",
        "meta.object-literal.key",
        "entity.name.variable.field",
        "meta.property-name",
        "meta.tag.attributes"
      ],
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Escape Characters",
      "scope": [
        "constant.character.escape",
        "constant.character.entity"
      ],
      "settings": {
        "foreground": "#66d9ff"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "keyword.operator.quantifier.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#66d9ff"
      }
    },
    {
      "name": "JSON Properties",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Markup Links",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "markup.link"
      ],
      "settings": {
        "foreground": "#66d9ff"
      }
    },
    {
      "name": "Invalid and Deprecated",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "name": "HTML/CSS Attribute Names",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ff971f"
      }
    },
    {
      "name": "HTML/CSS ID Attribute",
      "scope": [
        "entity.other.attribute-name.id"
      ],
      "settings": {
        "foreground": "#66d9ff"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": [
        "markup.inserted.diff"
      ],
      "settings": {
        "foreground": "#a6ff2e"
      }
    },
    {
      "name": "Diff Deleted",
      "scope": [
        "markup.deleted",
        "markup.deleted.diff"
      ],
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Diff Changed",
      "scope": [
        "markup.changed.diff"
      ],
      "settings": {
        "foreground": "#e6db74"
      }
    },
    {
      "name": "Diff Header Files",
      "scope": [
        "meta.diff.header.from-file",
        "meta.diff.header.to-file",
        "punctuation.definition.from-file.diff",
        "punctuation.definition.to-file.diff"
      ],
      "settings": {
        "foreground": "#66d9ff"
      }
    },
    {
      "name": "Debug Tokens",
      "scope": [
        "token.info-token"
      ],
      "settings": {
        "foreground": "#0383b5"
      }
    },
    {
      "name": "Warn Tokens",
      "scope": [
        "token.warn-token"
      ],
      "settings": {
        "foreground": "#ff971f"
      }
    },
    {
      "name": "Error Tokens",
      "scope": [
        "token.error-token"
      ],
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Debug Tokens",
      "scope": [
        "token.debug-token"
      ],
      "settings": {
        "foreground": "#ae81ff"
      }
    }
  ],
