{
  "name": "Monokai Nebula Light",
  "type": "light",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "annotation:dart": {
      "foreground": "#8d22e9"
    },
    "enumMember": {
      "foreground": "#0383b5"
    },
    "macro": {
      "foreground": "#8d22e9"
    },
    "memberOperatorOverload": {
      "foreground": "#d01655"
    },
    "parameter.label:dart": {
      "foreground": "#202020"
    },
    "property:dart": {
      "foreground": "#479802"
    },
    "tomlArrayKey": {
      "foreground": "#9a7f0a"
    },
    "variable:dart": {
      "foreground": "#202020"
    },
    "variable.constant": {
      "foreground": "#8d22e9"
    },
    "variable.defaultLibrary": {
      "foreground": "#0383b5"
    }
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment",
        "comment markup.link",
        "markup.quote.markdown",
        "string.quoted.docstring"
      ],
      "settings": {
        "foreground": "#858575"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "entity.name.namespace",
        "variable",
        "variable.other",
        "variable.parameter.function",
        "variable.other.readwrite",
        "variable.other.readwrite.c",
        "variable.parameter",
        "variable.language.rust",
        "variable:dart",
        "variable.parameter.function.language.python",
        "support.variable.property",
        "support.variable.object.process",
        "support.variable.object.node"
      ],
      "settings": {
        "foreground": "#202020"
      }
    },
    {
      "name": "Special Variables",
      "scope": [
        "variable.parameter.function.language.special.self.python"
      ],
      "settings": {
        "foreground": "#e67100"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "support.constant",
        "support.constant.math",
        "support.constant.core.rust",
        "support.constant.ext.php",
        "support.constant.std.php",
        "support.constant.core.php",
        "support.constant.parser-token.php",
        "variable.other.constant",
        "variable.other.enummember",
        "variable.constant"
      ],
      "settings": {
        "foreground": "#8d22e9"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.unquoted",
        "string.regexp",
        "string.other"
      ],
      "settings": {
        "foreground": "#9a7f0a"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical.python",
        "keyword.other.unit",
        "storage",
        "storage.type",
        "storage.modifier",
        "punctuation.definition.decorator.python"
      ],
      "settings": {
        "foreground": "#d01655"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "meta.function-call.generic.python",
        "variable.function",
        "support.function",
        "support.function.console",
        "support.function.std.rust"
      ],
      "settings": {
        "foreground": "#479802"
      }
    },
    {
      "name": "Classes and Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.scope",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#0383b5"
      }
    },
    {
      "name": "Markup Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "markup.heading",
        "markup.inline.raw",
        "markup.bold",
        "markup.italic"
      ],
      "settings": {
        "foreground": "#d01655"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.bitwise"
      ],
      "settings": {
        "foreground": "#d01655"
      }
    },
    {
      "name": "Assignment Operators",
      "scope": [
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#479802"
      }
    },
    {
      "name": "Unpacking Operators",
      "scope": [
        "keyword.operator.unpacking.parameter.python",
        "keyword.operator.unpacking.arguments.python"
      ],
      "settings": {
        "foreground": "#d01655"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#202020"
      }
    },
    {
      "name": "Special Functions and Methods",
      "scope": [
        "entity.name.function.special",
        "entity.name.function.member",
        "support.function.magic",
        "support.function.builtin",
        "support.function.builtin.python",
        "keyword.other.special-method",
        "markup.inserted",
        "meta.method-call",
        "meta.method"
      ],
      "settings": {
        "foreground": "#0383b5"
      }
    },
    {
      "name": "Object Properties",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "support.variable.magic.python",
        "meta.object-literal.key",
        "entity.name.variable.field",
        "meta.property-name",
        "meta.tag.attributes"
      ],
      "settings": {
        "foreground": "#d01655"
      }
    },
    {
      "name": "Escape Characters",
      "scope": [
        "constant.character.escape",
        "constant.character.entity"
      ],
      "settings": {
        "foreground": "#0383b5"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "keyword.operator.quantifier.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#0383b5"
      }
    },
    {
      "name": "JSON Properties",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#d01655"
      }
    },
    {
      "name": "Markup Links",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "markup.link"
      ],
      "settings": {
        "foreground": "#0383b5"
      }
    },
    {
      "name": "Invalid and Deprecated",
      "scope": [
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#101010"
      }
    },
    {
      "name": "HTML/CSS Attribute Names",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#e67100"
      }
    },
    {
      "name": "HTML/CSS ID Attribute",
      "scope": [
        "entity.other.attribute-name.id"
      ],
      "settings": {
        "foreground": "#0383b5"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": [
        "markup.inserted.diff"
      ],
      "settings": {
        "foreground": "#479802"
      }
    },
    {
      "name": "Diff Deleted",
      "scope": [
        "markup.deleted",
        "markup.deleted.diff"
      ],
      "settings": {
        "foreground": "#d01655"
      }
    },
    {
      "name": "Diff Changed",
      "scope": [
        "markup.changed.diff"
      ],
      "settings": {
        "foreground": "#9a7f0a"
      }
    },
    {
      "name": "Diff Header Files",
      "scope": [
        "meta.diff.header.from-file",
        "meta.diff.header.to-file",
        "punctuation.definition.from-file.diff",
        "punctuation.definition.to-file.diff"
      ],
      "settings": {
        "foreground": "#0383b5"
      }
    },
    {
      "name": "Info Tokens",
      "scope": [
        "token.info-token"
      ],
      "settings": {
        "foreground": "#0383b5"
      }
    },
    {
      "name": "Warn Tokens",
      "scope": [
        "token.warn-token"
      ],
      "settings": {
        "foreground": "#e67100"
      }
    },
    {
      "name": "Error Tokens",
      "scope": [
        "token.error-token"
      ],
      "settings": {
        "foreground": "#d01655"
      }
    },
    {
      "name": "Debug Tokens",
      "scope": [
        "token.debug-token"
      ],
      "settings": {
        "foreground": "#8d22e9"
      }
    }
  ],
